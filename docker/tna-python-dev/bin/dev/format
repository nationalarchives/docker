#!/bin/bash

set -e

cd /app || return

[[ -z $FIX ]] && FIX=true

if [ "$FIX" = true ]
then
  echo "Fixing issues..."
else
  echo "Reporting issues without fixing..."
fi
echo

echo "Running ruff..."
if [ -f "/app/ruff.toml" ]
then
  RUFF_CONFIG="/app/ruff.toml"
  echo "Using app config ($RUFF_CONFIG)"
else
  RUFF_CONFIG="/home/app/ruff.toml"
  echo "Using default config ($RUFF_CONFIG)"
fi
if [ "$FIX" = true ]
then
  ruff check /app --fix --config "$RUFF_CONFIG"
  ruff format /app --config "$RUFF_CONFIG"
else
  ruff check /app --config "$RUFF_CONFIG"
  ruff format --check /app --config "$RUFF_CONFIG"
fi
echo

if [ -d "/app/app/templates" ]
then
  echo "Running djLint..."
  if [ -f "/app/.djlintrc" ]
  then
    DJLINT_CONFIG="/app/.djlintrc"
    echo "Using app config ($DJLINT_CONFIG)"
  else
    DJLINT_CONFIG="/home/app/.djlintrc"
    echo "Using default config ($DJLINT_CONFIG, Jinja2)"
  fi
  djlint /app/app/templates --configuration "$DJLINT_CONFIG" --lint --quiet
  # if [ "$FIX" = true ]
  # then
  #   # djlint /app/app/templates --configuration "$DJLINT_CONFIG" --reformat --quiet || true
  #   # djhtml /app/app/templates --tabwidth 2
  #   echo
  # else
  #   # djhtml /app/app/templates --tabwidth 2 --check
  #   echo
  # fi
  echo
fi

. install-format-dependencies
echo

echo "Running prettier..."
if [ -f "/app/.prettierignore" ]
then
  PRETTIER_IGNORE="/app/.prettierignore"
  echo "Using app config ($PRETTIER_IGNORE)"
else
  PRETTIER_IGNORE="/home/app/.prettierignore"
  echo "Using default config ($PRETTIER_IGNORE)"
fi
if [ "$FIX" = true ]
then
  prettier --ignore-path "$PRETTIER_IGNORE" --write --list-different /app
else
  prettier --ignore-path "$PRETTIER_IGNORE" --list-different /app
fi
echo

echo "Running stylelint..."
if [ -f "/app/.stylelintrc" ]
then
  STYLELINT_CONFIG="/app/.stylelintrc"
  echo "Using app config ($STYLELINT_CONFIG)"
elif [ -f "/app/stylelint.config.js" ]
then
  STYLELINT_CONFIG="/app/stylelint.config.js"
  echo "Using app config ($STYLELINT_CONFIG)"
elif [ -f "/app/.stylelintrc.js" ]
then
  STYLELINT_CONFIG="/app/.stylelintrc.js"
  echo "Using app config ($STYLELINT_CONFIG)"
elif [ -f "/app/stylelint.config.mjs" ]
then
  STYLELINT_CONFIG="/app/stylelint.config.mjs"
  echo "Using app config ($STYLELINT_CONFIG)"
elif [ -f "/app/.stylelintrc.mjs" ]
then
  STYLELINT_CONFIG="/app/.stylelintrc.mjs"
  echo "Using app config ($STYLELINT_CONFIG)"
elif [ -f "/app/stylelint.config.cjs" ]
then
  STYLELINT_CONFIG="/app/stylelint.config.cjs"
  echo "Using app config ($STYLELINT_CONFIG)"
elif [ -f "/app/.stylelintrc.cjs" ]
then
  STYLELINT_CONFIG="/app/.stylelintrc.cjs"
  echo "Using app config ($STYLELINT_CONFIG)"
elif [ -f "/app/.stylelintrc.json" ]
then
  STYLELINT_CONFIG="/app/.stylelintrc.json"
  echo "Using app config ($STYLELINT_CONFIG)"
elif [ -f "/app/.stylelintrc.yml" ]
then
  STYLELINT_CONFIG="/app/.stylelintrc.yml"
  echo "Using app config ($STYLELINT_CONFIG)"
elif [ -f "/app/.stylelintrc.yaml" ]
then
  STYLELINT_CONFIG="/app/.stylelintrc.yaml"
  echo "Using app config ($STYLELINT_CONFIG)"
else
  STYLELINT_CONFIG="/home/app/stylelint.config.js"
  echo "Using default config ($STYLELINT_CONFIG)"
fi
if [ -f "/app/.stylelintignore" ]
then
  STYLELINT_IGNORE="/app/.stylelintignore"
  echo "Using app ignore ($STYLELINT_IGNORE)"
else
  STYLELINT_IGNORE="/home/app/.stylelintignore"
  echo "Using default ignore ($STYLELINT_IGNORE)"
fi
if [ "$FIX" = true ]
then
  stylelint --config "$STYLELINT_CONFIG" --ignore-path "$STYLELINT_IGNORE" --fix "/app/**/*.{css,scss}" --allow-empty-input
else
  stylelint --config "$STYLELINT_CONFIG" --ignore-path "$STYLELINT_IGNORE" "/app/**/*.{css,scss}" --allow-empty-input
fi
echo

echo "Running eslint..."
if [ -f "/app/.eslintrc.js" ]
then
  ESLINT_CONFIG="/app/.eslintrc.js"
  echo "Using app config ($ESLINT_CONFIG)"
elif [ -f "/app/.eslintrc.mjs" ]
then
  ESLINT_CONFIG="/app/.eslintrc.mjs"
  echo "Using app config ($ESLINT_CONFIG)"
elif [ -f "/app/.eslintrc.cjs" ]
then
  ESLINT_CONFIG="/app/.eslintrc.cjs"
  echo "Using app config ($ESLINT_CONFIG)"
elif [ -f "/app/eslintrc.config.js" ]
then
  ESLINT_CONFIG="/app/eslintrc.config.js"
  echo "Using app config ($ESLINT_CONFIG)"
elif [ -f "/app/eslintrc.config.mjs" ]
then
  ESLINT_CONFIG="/app/eslintrc.config.mjs"
  echo "Using app config ($ESLINT_CONFIG)"
elif [ -f "/app/eslintrc.config.cjs" ]
then
  ESLINT_CONFIG="/app/eslintrc.config.cjs"
  echo "Using app config ($ESLINT_CONFIG)"
else
  ESLINT_CONFIG="/home/app/.eslintrc.js"
  echo "Using default config ($ESLINT_CONFIG)"
fi
if [ "$FIX" = true ]
then
  eslint --config "$ESLINT_CONFIG" --no-error-on-unmatched-pattern --fix "/app"
else
  eslint --config "$ESLINT_CONFIG" --no-error-on-unmatched-pattern "/app"
fi
