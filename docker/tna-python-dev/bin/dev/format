#!/bin/bash

set -e

[[ -z $FIX ]] && FIX=true

if [ "$FIX" = true ]
then
  echo "Fixing issues..."
else
  echo "Reporting issues without fixing..."
fi
echo

[[ -z $STRICT ]] && STRICT=false
if [[ "$1" == "--strict" ]]; then
  STRICT=true
fi

cd /app || return

# ==========================================
# RUFF
# ==========================================
echo "Running ruff..."
if [ -f "/app/ruff.toml" ]
then
  RUFF_CONFIG="/app/ruff.toml"
  if [ "$STRICT" = true ]
  then
    echo "Using app config ($RUFF_CONFIG - ignoring strict mode)"
  else
    echo "Using app config ($RUFF_CONFIG)"
  fi
elif [ "$STRICT" = true ]
then
  RUFF_CONFIG="/home/app/ruff-strict.toml"
  echo "Using default strict config ($RUFF_CONFIG)"
else
  RUFF_CONFIG="/home/app/ruff.toml"
  echo "Using default config ($RUFF_CONFIG)"
fi
if [ "$FIX" = true ]
then
  ruff check /app --fix --config "$RUFF_CONFIG"
  ruff format /app --config "$RUFF_CONFIG"
else
  ruff check /app --config "$RUFF_CONFIG"
  ruff format --check /app --config "$RUFF_CONFIG"
fi
echo

# ==========================================
# DJLINT
# ==========================================
if [ -d "/app/app/templates" ]
then
  echo "Running djLint..."
  if [ -f "/app/.djlintrc" ]
  then
    DJLINT_CONFIG="/app/.djlintrc"
    echo "Using app config ($DJLINT_CONFIG)"
  else
    DJLINT_CONFIG="/home/app/.djlintrc"
    echo "Using default config ($DJLINT_CONFIG, Jinja2)"
  fi
  djlint /app/app/templates --configuration "$DJLINT_CONFIG" --lint --quiet
  # if [ "$FIX" = true ]
  # then
  #   # djlint /app/app/templates --configuration "$DJLINT_CONFIG" --reformat --quiet || true
  #   echo
  # fi
  echo
fi

# ==========================================
# SET UP NODE
# ==========================================
. tna-nvm
nvm use default
NODE_GLOBAL_MODULES="$(npm root --global)"

# ==========================================
# STYLELINT
# ==========================================
echo "Running stylelint..."
if [ -f "/app/stylelint.config.mjs" ]
then
  STYLELINT_CONFIG="/app/stylelint.config.mjs"
  echo "Using app config ($STYLELINT_CONFIG)"
else
  STYLELINT_CONFIG="$NODE_GLOBAL_MODULES/@nationalarchives/stylelint-config/stylelint.config.mjs"
  echo "Using default config from TNA Frontend ($STYLELINT_CONFIG)"
fi
if [ -f "/app/.stylelintignore" ]
then
  STYLELINT_IGNORE="/app/.stylelintignore"
  echo "Using app ignore ($STYLELINT_IGNORE)"
else
  STYLELINT_IGNORE="/home/app/.stylelintignore"
  echo "Using default ignore ($STYLELINT_IGNORE)"
fi
STYLELINT_BIN="$NODE_GLOBAL_MODULES/@nationalarchives/stylelint-config/node_modules/stylelint/bin/stylelint.mjs"
if [ "$FIX" = true ]
then
  node "$STYLELINT_BIN" --config "$STYLELINT_CONFIG" --ignore-path "$STYLELINT_IGNORE" --fix "/app/**/*.{css,scss}" --allow-empty-input
else
  node "$STYLELINT_BIN" --config "$STYLELINT_CONFIG" --ignore-path "$STYLELINT_IGNORE" "/app/**/*.{css,scss}" --allow-empty-input
fi
echo

# ==========================================
# ESLINT
# ==========================================
echo "Running eslint..."
if [ -f "/app/eslint.config.mjs" ]
then
  ESLINT_CONFIG="/app/eslint.config.mjs"
  echo "Using app config ($ESLINT_CONFIG)"
else
  ESLINT_CONFIG="$NODE_GLOBAL_MODULES/@nationalarchives/eslint-config/eslint.config.mjs"
  echo "Using default config from TNA Frontend ($ESLINT_CONFIG)"
fi
ESLINT_BIN="$NODE_GLOBAL_MODULES/@nationalarchives/eslint-config/node_modules/eslint/bin/eslint.js"
if [ "$FIX" = true ]
then
  node "$ESLINT_BIN" --config "$ESLINT_CONFIG" --no-error-on-unmatched-pattern --fix "/app"
else
  node "$ESLINT_BIN" --config "$ESLINT_CONFIG" --no-error-on-unmatched-pattern "/app"
fi

# ==========================================
# PRETTIER
# ==========================================
echo "Running prettier..."
if [ -f "/app/.prettierignore" ]
then
  PRETTIER_IGNORE="/app/.prettierignore"
  echo "Using app config ($PRETTIER_IGNORE)"
else
  PRETTIER_IGNORE="/home/app/.prettierignore"
  echo "Using default config ($PRETTIER_IGNORE)"
fi
if [ "$FIX" = true ]
then
  prettier --ignore-path "$PRETTIER_IGNORE" --write --list-different --no-error-on-unmatched-pattern /app
else
  prettier --ignore-path "$PRETTIER_IGNORE" --list-different --no-error-on-unmatched-pattern /app
fi
echo
