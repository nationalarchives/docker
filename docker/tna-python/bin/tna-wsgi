#!/bin/bash

set -e

echo "Running application..."
echo

# Get the application
APPLICATION=$1

# Error if no application is passed
if [ -z "$APPLICATION" ]
then
  echo -e "Error: application not specified\n"
  echo "PARAMETERS"
  echo "  application          the Python package you want to run"
  echo "                       Examples: tna-wsgi my_app:app"
  echo "                                 tna-asgi my_app:app"
  exit 1
fi

# if a gunicorn.conf.py file exists, use it for configuration
if [ -f "/app/gunicorn.conf.py" ]
then
  echo "Starting gunicorn (using gunicorn.conf.py)..."
  poetry run gunicorn "$APPLICATION" --config "/app/gunicorn.conf.py" --capture-output --enable-stdio-inheritance
else
  # Set up the configuration for gunicorn based on environment variables or defaults
  [[ -z $WORKERS ]] && WORKERS=$(python -c "import multiprocessing; print(multiprocessing.cpu_count() * 2 + 1)")
  [[ -z $WORKER_CONNECTIONS ]] && WORKER_CONNECTIONS=1000
  [[ -z $MAX_REQUESTS ]] && MAX_REQUESTS=10000
  [[ -z $MAX_REQUESTS_JITTER ]] && MAX_REQUESTS_JITTER=1000
  [[ -z $LOG_LEVEL ]] && LOG_LEVEL=warning
  [[ -z $TIMEOUT ]] && TIMEOUT=30
  [[ -z $WORKER_CLASS ]] && WORKER_CLASS=sync

  # Get the protcol for the application
  APPLICATION_PROTOCOL=$(echo "${APPLICATION_PROTOCOL:-https}" | tr '[:upper:]' '[:lower:]')

  echo "Configuration:"
  echo "  Application: $APPLICATION"
  echo "  Workers: $WORKERS"
  echo "  Worker connections: $WORKER_CONNECTIONS"
  echo "  Max requests: $MAX_REQUESTS"
  echo "  Max requests jitter: $MAX_REQUESTS_JITTER"
  echo "  Log level: $LOG_LEVEL"
  echo "  Timeout: $TIMEOUT"
  echo "  Worker class: $WORKER_CLASS"
  echo "  Application protocol: $APPLICATION_PROTOCOL"
  echo

  if [ "$APPLICATION_PROTOCOL" = "https" ]
  then
    source tna-ssl-setup
    echo "Starting gunicorn ($WORKER_CLASS, $APPLICATION_PROTOCOL)..."
    poetry run gunicorn "$APPLICATION" --worker-class "$WORKER_CLASS" --workers "$WORKERS" --worker-connections "$WORKER_CONNECTIONS" --max-requests "$MAX_REQUESTS" --max-requests-jitter "$MAX_REQUESTS_JITTER" --log-level "$LOG_LEVEL" --timeout "$TIMEOUT" --access-logfile - --bind "0.0.0.0:$APPLICATION_PORT" --keyfile "$SSL_KEY_FILE" --certfile "$SSL_CERTIFICATE_FILE" --ca-certs "$SSL_CA_CERTIFICATES_FILE" --preload --capture-output --enable-stdio-inheritance
  elif [ "$APPLICATION_PROTOCOL" = "http" ]
  then
    echo "Starting gunicorn ($WORKER_CLASS, $APPLICATION_PROTOCOL)..."
    poetry run gunicorn "$APPLICATION" --worker-class "$WORKER_CLASS" --workers "$WORKERS" --worker-connections "$WORKER_CONNECTIONS" --max-requests "$MAX_REQUESTS" --max-requests-jitter "$MAX_REQUESTS_JITTER" --log-level "$LOG_LEVEL" --timeout "$TIMEOUT" --access-logfile - --bind "0.0.0.0:$APPLICATION_PORT" --preload --capture-output --enable-stdio-inheritance
  else
    echo -e "Error: invalid protocol specified in APPLICATION_PROTOCOL: '$APPLICATION_PROTOCOL'\n"
    echo "Allowed values are 'http' and 'https'"
    exit 1
  fi
fi
